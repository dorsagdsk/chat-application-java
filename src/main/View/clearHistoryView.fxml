<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="229.0" prefWidth="308.0" style="-fx-background-color: #756969; -fx-border-width: 5; -fx-border-color: #ff7700;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ClearHController">
   <children>
      <Label alignment="CENTER" layoutX="27.0" layoutY="26.0" prefHeight="41.0" prefWidth="231.0" text=" clear history?">
         <font>
            <Font name="Monotype Corsiva" size="31.0" />
         </font>
         <textFill>
            <LinearGradient endX="1.0" endY="1.0">
               <stops>
                  <Stop>
                     <color>
                        <Color red="0.9473684430122375" green="0.4263157844543457" />
                     </color>
                  </Stop>
                  <Stop offset="1.0">
                     <color>
                        <Color />
                     </color>
                  </Stop>
               </stops>
            </LinearGradient>
         </textFill>
      </Label>
      <Button fx:id="acceptBTN" layoutX="172.0" layoutY="101.0" mnemonicParsing="false" onAction="#acceptHandler" prefHeight="51.0" prefWidth="61.0" text="Yes" textFill="#030303">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Button fx:id="rejectBTN" layoutX="68.0" layoutY="101.0" mnemonicParsing="false" onAction="#rejectHandler" prefHeight="51.0" prefWidth="61.0" text="No">
         <font>
            <Font size="13.0" />
         </font>
      </Button>

   </children>
</AnchorPane>
