    <padding>
        <Insets right="-195.0" />
    </padding>
    <children>
        <Label fx:id="groupNameLBL" alignment="CENTER" layoutX="192.0" layoutY="17.0" prefHeight="44.0" prefWidth="74.0" style="-fx-background-color: #756969;">
            <font>
                <Font name="System Bold Italic" size="20.0" />
            </font>
        </Label>
        <TextField fx:id="messageFLD" layoutX="29.0" layoutY="580.0" prefHeight="44.0" prefWidth="461.0" promptText="Type here" style="-fx-border-color: black; -fx-border-width: 4;">
            <font>
                <Font name="Cooper Black" size="16.0" />
            </font>
        </TextField>
        <Button fx:id="sendBTN" blendMode="MULTIPLY" layoutX="490.0" layoutY="583.0" mnemonicParsing="false" onAction="#sendHandler" prefHeight="38.0" prefWidth="49.0" style="-fx-background-color: #e6e6fa; -fx-border-color: black; -fx-border-width: 2;" text="➜">
