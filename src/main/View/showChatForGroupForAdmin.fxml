                <Font name="Century Schoolbook Bold Italic" size="16.0" />
            </font>
        </Label>
        <TableView fx:id="chatTable" layoutX="29.0" layoutY="113.0" prefHeight="463.0" prefWidth="514.0" style="-fx-border-color: black; -fx-border-width: 3;">
            <columns>
                <TableColumn fx:id="messageColumn" prefWidth="292.6666660308838" text="Message" />
                <TableColumn fx:id="senderUsernameColumn" prefWidth="106.66668701171875" text="Sender" />
                <TableColumn fx:id="dateAndTimeColumn" prefWidth="103.33328247070312" text="Time" />
