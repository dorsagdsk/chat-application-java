                  <MenuItem fx:id="deleteMessageBTN" mnemonicParsing="false" onAction="#deleteMessageHandler" text="Delete message" />
                  <MenuItem fx:id="clearHistoryBTN" mnemonicParsing="false" onAction="#clearHistoryHandler" text="clear history" />
                  <MenuItem fx:id="closeBTN" mnemonicParsing="false" onAction="#closeHandler" text="Close" />
