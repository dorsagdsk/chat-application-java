<AnchorPane prefHeight="647.0" prefWidth="574.0" style="-fx-background-color: #756969; -fx-border-width: 10; -fx-border-color: #ff7700;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ShowChatForGroupAdminController">
    <opaqueInsets>
