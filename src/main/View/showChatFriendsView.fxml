<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="584.0" prefWidth="542.0" style="-fx-background-color: #756969; -fx-border-width: 6; -fx-border-color: #ff7700;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ShowPVFriendsController">
    <opaqueInsets>
        <Insets />
    </opaqueInsets>
    <padding>
        <Insets right="-195.0" />
    </padding>
    <children>
        <Label fx:id="usernameTitleLBL" alignment="CENTER" layoutX="154.0" layoutY="14.0" prefHeight="44.0" prefWidth="108.0" style="-fx-background-color: #756969;">
            <font>
                <Font name="System Bold Italic" size="18.0" />
            </font>
        </Label>
        <TextField fx:id="messageFLD" layoutX="24.0" layoutY="505.0" prefHeight="44.0" prefWidth="438.0" promptText="Type here" style="-fx-border-color: black; -fx-border-width: 4;">
            <font>
                <Font name="Cooper Black" size="16.0" />
            </font>
        </TextField>
        <Button fx:id="sendBTN" blendMode="MULTIPLY" layoutX="473.0" layoutY="508.0" mnemonicParsing="false" onAction="#sendHandler" prefHeight="38.0" prefWidth="47.0" style="-fx-background-color: #e6e6fa; -fx-border-color: black; -fx-border-width: 2;" text="➜">
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor>
            <font>
                <Font size="10.0" />
            </font></Button>
        <Label fx:id="errorLBL" alignment="CENTER" layoutX="192.0" layoutY="388.0" prefHeight="20.0" prefWidth="410.0" textFill="#d4153f">
            <font>
                <Font name="Century Schoolbook Bold Italic" size="16.0" />
            </font>
        </Label>
        <TableView fx:id="chatTable" layoutX="14.0" layoutY="112.0" prefHeight="373.0" prefWidth="513.0" style="-fx-border-color: black; -fx-border-width: 3;">
            <columns>
                <TableColumn fx:id="messageColumn" prefWidth="290.6666259765625" text="Message" />
                <TableColumn fx:id="senderUsernameColumn" prefWidth="95.33331298828125" text="Sender" />
                <TableColumn fx:id="dateAndTimeColumn" prefWidth="130.0" text="Time" />
            </columns>
        </TableView>
      <MenuBar layoutX="438.0" layoutY="51.0" prefHeight="25.0" prefWidth="70.0">
        <menus>
          <Menu mnemonicParsing="false" text="|||&gt;|||&gt;">
            <items>
              <MenuItem fx:id="closeBTN" mnemonicParsing="false" onAction="#closeHandler" text="Close" />
                  <MenuItem fx:id="editBTN" mnemonicParsing="false" onAction="#editHandler" text="Edite" />
                  <MenuItem fx:id="deleteMessageBTN" mnemonicParsing="false" onAction="#deleteMessageHandler" text="Delete" />
                  <MenuItem fx:id="openLinkBTN" mnemonicParsing="false" onAction="#openLinkHandler" text="openLink" />
                  <MenuItem fx:id="clearHistoryBTN" mnemonicParsing="false" onAction="#clearHistoryHandler" text="Clear History" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
      <ImageView fitHeight="84.0" fitWidth="87.0" layoutX="67.0" layoutY="22.0" pickOnBounds="true" preserveRatio="true" style="-fx-blend-mode: #ff7700;">
         <image>
            <Image url="@image/images.jpg" />
         </image>
      </ImageView>
      <Label layoutX="175.0" layoutY="75.0" text="online" />
      <Button layoutX="6.0" layoutY="51.0" mnemonicParsing="false" onAction="#closeHandler" prefHeight="38.0" prefWidth="61.0" style="-fx-background-color: #756969;" text="⟵">
         <font>
            <Font size="17.0" />
         </font>
      </Button>
    </children>
</AnchorPane>
