<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="290.0" prefWidth="288.0" style="-fx-background-color: #756969; -fx-border-width: 5; -fx-border-color: #ff7700;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.OpenLinkController">
   <children>
      <Label alignment="CENTER" layoutX="60.0" layoutY="92.0" prefHeight="35.0" prefWidth="169.0" text="Click on link ">
         <font>
            <Font name="Monotype Corsiva" size="29.0" />
         </font>
         <textFill>
            <LinearGradient endX="1.0" endY="1.0">
               <stops>
                  <Stop>
                     <color>
                        <Color red="1.0" green="0.4166666567325592" />
                     </color>
                  </Stop>
                  <Stop offset="1.0">
                     <color>
                        <Color red="1.0" green="1.0" />
                     </color>
                  </Stop>
               </stops>
            </LinearGradient>
         </textFill>
      </Label>
      <Label alignment="CENTER" layoutX="60.0" layoutY="136.0" prefHeight="83.0" prefWidth="169.0" style="-fx-border-color: #ff7700; -fx-border-width: 2;" textFill="#74287e">
         <font>
            <Font name="Century Schoolbook Bold Italic" size="15.0" />
         </font>
      </Label>
      <Hyperlink fx:id="hyperlink" alignment="CENTER" layoutX="68.0" layoutY="147.0" onAction="#hyperlinkHandler" prefHeight="61.0" prefWidth="151.0" textFill="#fffefe">
         <font>
            <Font size="18.0" />
         </font>
      </Hyperlink>
   </children>
</AnchorPane>
