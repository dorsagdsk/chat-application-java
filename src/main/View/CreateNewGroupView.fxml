<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="383.0" prefWidth="340.0" style="-fx-background-color: #756969; -fx-border-width: 5; -fx-border-color: #ff7700;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.CreateNewGroupController">
   <children>
      <Label alignment="CENTER" layoutX="89.0" layoutY="21.0" prefHeight="35.0" prefWidth="210.0" text="Add Group">
         <font>
            <Font name="Monotype Corsiva" size="32.0" />
         </font>
         <textFill>
            <LinearGradient endX="1.0" endY="1.0">
               <stops>
                  <Stop>
                     <color>
                        <Color red="1.0" green="0.2684284448623657" />
                     </color>
                  </Stop>
                  <Stop offset="1.0">
                     <color>
                        <Color red="0.15789473056793213" green="0.0906432718038559" blue="0.0906432718038559" />
                     </color>
                  </Stop>
               </stops>
            </LinearGradient>
         </textFill>
      </Label>

      <TextField fx:id="groupNameFLD" layoutX="135.0" layoutY="147.0" prefHeight="29.0" prefWidth="169.0" promptText=" Name">
         <font>
            <Font name="Century Schoolbook Bold Italic" size="14.0" />
         </font>
      </TextField>
      <Label layoutX="43.0" layoutY="143.0" prefHeight="21.0" prefWidth="92.0" text=" Name" textFill="WHITE">
         <font>
            <Font name="Monotype Corsiva" size="29.0" />
         </font>
      </Label>
      <TextField fx:id="linkFLD" layoutX="135.0" layoutY="222.0" prefHeight="29.0" prefWidth="169.0" promptText="Link">
         <font>
            <Font name="Century Schoolbook Bold Italic" size="14.0" />
         </font>
      </TextField>
      <Label layoutX="49.0" layoutY="218.0" text="Link" textFill="WHITE">
         <font>
            <Font name="Monotype Corsiva" size="30.0" />
         </font>
      </Label>
      <Label fx:id="errorLBL" alignment="CENTER" layoutX="67.0" layoutY="266.0" prefHeight="20.0" prefWidth="254.0" textFill="#d4153f">
         <font>
            <Font name="Century Schoolbook Bold Italic" size="16.0" />
         </font>
      </Label>
      <Button fx:id="createBTN" layoutX="244.0" layoutY="279.0" mnemonicParsing="false" onAction="#createHandler" prefHeight="38.0" prefWidth="60.0" style="-fx-background-color: #ff7700;" text="Add" textFill="#1b0909">
         <font>
            <Font size="17.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Button fx:id="closeBTN" layoutX="23.0" layoutY="23.0" mnemonicParsing="false" onAction="#closeHandler" prefHeight="29.0" prefWidth="52.0" style="-fx-background-color: silver;" text="⟵" textFill="#140a0a">
         <font>
            <Font name="System Bold Italic" size="17.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
   </children>
</AnchorPane>
